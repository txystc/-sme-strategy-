{
  "nbformat": 4,
  "nbformat_minor": 0,
  "metadata": {
    "colab": {
      "provenance": [],
      "name": "build_kivy_apk.ipynb"
    },
    "kernelspec": {
      "name": "python3",
      "display_name": "Python 3"
    }
  },
  "cells": [
    {
      "cell_type": "markdown",
      "source": [
        "# 🐍 Kivy 安卓 APK 云端构建\n",
        "\n",
        "> 运行本 notebook，免费在 Google Colab 上构建你的 Kivy App APK\n",
        "\n",
        "**耗时**：首次约 20~30 分钟（要下载 Android SDK）\n",
        "\n",
        "---\n",
        "\n",
        "## 1️⃣ 上传你的代码"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 上传 main.py 和 buildozer.spec（点击运行后选择文件上传）\n",
        "from google.colab import files\n",
        "import os\n",
        "\n",
        "os.makedirs('/content/app', exist_ok=True)\n",
        "print('请在下方上传 main.py 和 buildozer.spec')\n",
        "uploaded = files.upload()\n",
        "for fn in uploaded.keys():\n",
        "    print(f'已上传: {fn}')"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 确认文件已上传\n",
        "import os\n",
        "for f in os.listdir('/content'):\n",
        "    print(f)\n",
        "for f in os.listdir('/content/app'):\n",
        "    print('app/', f)"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 2️⃣ 安装构建依赖（约 5 分钟）"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 安装系统依赖\n",
        "!apt-get update -qq\n",
        "!apt-get install -y -qq \\\n",
        "    python3-pip python3-dev \\\n",
        "    openjdk-17-jdk-headless \\\n",
        "    autoconf libtool pkg-config \\\n",
        "    zlib1g-dev libncurses5-dev \\\n",
        "    libsdl2-dev libsdl2-image-dev \\\n",
        "    libsdl2-mixer-dev libsdl2-ttf-dev \\\n",
        "    libswscale-dev libffi-dev libssl-dev \\\n",
        "    cmake git\n",
        "\n",
        "!echo \"JAVA_HOME=/usr/lib/jvm/java-17-openjdk-amd64\" >> /etc/environment\n",
        "!java -version"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 3️⃣ 安装 Python 依赖"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "!pip install --upgrade pip -q\n",
        "!pip install buildozer kivy -q\n",
        "!pip install cython==0.29.33 -q\n",
        "!python -c \"import kivy; print('Kivy', kivy.__version__)\""
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 4️⃣ 移动文件并构建 APK（约 20 分钟）"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 复制文件到构建目录\n",
        "import shutil, os\n",
        "\n",
        "os.makedirs('/root/.buildozer', exist_ok=True)\n",
        "\n",
        "# 如果上传了文件到 /content 根目录\n",
        "for fn in os.listdir('/content'):\n",
        "    if fn.endswith('.py') or fn.endswith('.spec'):\n",
        "        shutil.copy(f'/content/{fn}', f'/content/app/{fn}')\n",
        "        print(f'复制 {fn} -> app/')\n",
        "\n",
        "# 列出 app 目录\n",
        "for f in os.listdir('/content/app'):\n",
        "    print('app/', f)"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 修改 buildozer.spec 适配 Colab\n",
        "spec = open('/content/app/buildozer.spec').read()\n",
        "\n",
        "# buildozer 默认需要 tty，Colab 里加这个参数\n",
        "spec = spec.replace('[buildozer]', '[buildozer]\nbuild_dir = /root/.buildozer') \n",
        "\n",
        "open('/content/app/buildozer.spec', 'w').write(spec)\n",
        "print('buildozer.spec 已更新')"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 开始构建！\n",
        "# 注意：Colab 有超时限制（约 90 分钟），构建过程需要稳定网络\n",
        "!cd /content/app && buildozer android debug --verbose 2>&1 | tee /content/build.log\n",
        "\n",
        "print('\\n=== 构建完成 ===')"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 检查 APK 是否生成\n",
        "import os\n",
        "bin_dir = '/content/app/bin'\n",
        "if os.path.exists(bin_dir):\n",
        "    apks = [f for f in os.listdir(bin_dir) if f.endswith('.apk')]\n",
        "    for a in apks:\n",
        "        path = os.path.join(bin_dir, a)\n",
        "        size = os.path.getsize(path) / 1024 / 1024\n",
        "        print(f'✅ APK 生成: {a} ({size:.1f} MB)')\n",
        "else:\n",
        "    print('❌ APK 未找到，检查 build.log 查找错误')\n",
        "    with open('/content/build.log') as f:\n",
        "        lines = f.readlines()\n",
        "        # 打印最后 50 行\n",
        "        for l in lines[-50:]:\n",
        "            print(l, end='')"
      ],
      "execution_count": None,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "## 5️⃣ 下载 APK"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "# 下载 APK 文件\n",
        "from google.colab import files\n",
        "bin_dir = '/content/app/bin'\n",
        "apks = [f for f in os.listdir(bin_dir) if f.endswith('.apk')]\n",
        "for a in apks:\n",
        "    files.download(os.path.join(bin_dir, a))\n",
        "print('下载完成！把 APK 传到手机安装即可。')"
      ],
      "execution_count": None,
      "outputs": []
    }
  ]
}
